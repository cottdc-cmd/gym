const BASELINE = { weight: 114.7, bf: 25.1, muscle: 46.3, score: 79 };
let entries = [];

function saveEntries() { /* in-memory only */ }

function logEntry() {
  const date = document.getElementById('logDate').value;
  const weight = parseFloat(document.getElementById('logWeight').value);
  const bf = parseFloat(document.getElementById('logBF').value);
  const muscle = parseFloat(document.getElementById('logMuscle').value);
  const score = parseFloat(document.getElementById('logScore').value);

  if (!date || isNaN(weight)) {
    alert('Please enter at least a date and weight.');
    return;
  }

  entries.unshift({ date, weight, bf: isNaN(bf) ? null : bf, muscle: isNaN(muscle) ? null : muscle, score: isNaN(score) ? null : score });
  saveEntries();
  renderEntries();

  document.getElementById('logDate').value = '';
  document.getElementById('logWeight').value = '';
  document.getElementById('logBF').value = '';
  document.getElementById('logMuscle').value = '';
  document.getElementById('logScore').value = '';
}

function delta(current, baseline, lowerIsBetter) {
  if (current === null || current === undefined) return '';
  const diff = (current - baseline).toFixed(1);
  const better = lowerIsBetter ? diff < 0 : diff > 0;
  const sign = diff > 0 ? '+' : '';
  const cls = better ? 'delta-pos' : (diff == 0 ? '' : 'delta-neg');
  return `<span class="${cls}">${sign}${diff}</span>`;
}

function renderEntries() {
  const list = document.getElementById('entriesList');
  if (!entries.length) {
    list.innerHTML = '<div class="empty-state">No weigh-ins logged yet. Add your first one above.</div>';
    return;
  }

  list.innerHTML = entries.map((e, i) => {
    const prev = entries[i + 1] || BASELINE;
    const weightDelta = e.weight && prev.weight ? ((e.weight - prev.weight) > 0 ? `<span class="delta-neg">+${(e.weight - prev.weight).toFixed(1)}</span>` : `<span class="delta-pos">${(e.weight - prev.weight).toFixed(1)}</span>`) : '';
    const bfDelta = e.bf != null && prev.bf != null ? (e.bf < prev.bf ? `<span class="delta-pos">${(e.bf - prev.bf).toFixed(1)}%</span>` : `<span class="delta-neg">+${(e.bf - prev.bf).toFixed(1)}%</span>`) : '';
    const muscleDelta = e.muscle != null && prev.muscle != null ? (e.muscle > prev.muscle ? `<span class="delta-pos">+${(e.muscle - prev.muscle).toFixed(1)} lbs</span>` : `<span class="delta-neg">${(e.muscle - prev.muscle).toFixed(1)} lbs</span>`) : '';

    const sinceBaseline = i === entries.length - 1 ? '' : `
      <div style="font-size:10px;color:var(--text-mid);margin-top:4px;">
        vs baseline: weight ${delta(e.weight, BASELINE.weight, true)} · bf ${e.bf != null ? delta(e.bf, BASELINE.bf, true) + '%' : '—'} · muscle ${e.muscle != null ? delta(e.muscle, BASELINE.muscle, false) + ' lbs' : '—'}
      </div>`;

    return `
      <div class="entry-card">
        <div class="entry-date">${new Date(e.date + 'T12:00:00').toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' })}</div>
        <div class="entry-stats">
          <div class="entry-stat"><span class="e-val">${e.weight}</span><span class="e-label">lbs</span></div>
          <div class="entry-stat"><span class="e-val">${e.bf != null ? e.bf + '%' : '—'}</span><span class="e-label">body fat</span></div>
          <div class="entry-stat"><span class="e-val">${e.muscle != null ? e.muscle : '—'}</span><span class="e-label">muscle lbs</span></div>
        </div>
        ${e.score != null ? `<div style="font-size:11px;color:var(--text-mid);margin-top:6px;">InBody score: <strong style="color:var(--debra-pink)">${e.score}</strong></div>` : ''}
        <div class="entry-delta">
          vs prev: weight ${weightDelta || '—'} · bf ${bfDelta || '—'} · muscle ${muscleDelta || '—'}
        </div>
        ${sinceBaseline}
      </div>`;
  }).join('');
}

