let currentView = 'both';

function setMainView(view, el) {
  document.querySelectorAll('.main-tab').forEach(t => t.className = 'main-tab');
  if (view === 'workouts') el.className = 'main-tab active-workout';
  else if (view === 'tracker') el.className = 'main-tab active-tracker';
  else el.className = 'main-tab active';
  document.querySelectorAll('.view-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('panel-' + view).classList.add('active');
}

function setView(view, el) {
  currentView = view;
  document.body.className = `view-${view}`;
  document.querySelectorAll('.person-tab').forEach(t => t.className = 'person-tab');
  el.className = `person-tab active-${view}`;
  renderMacros(view);
}

function renderMacros(view) {
  const bar = document.getElementById('macrosBar');
  bar.innerHTML = '';
  macroSets[view].forEach(m => {
    const div = document.createElement('div');
    div.className = `macro-block ${m.cls}`;
    div.innerHTML = `<span class="label">${m.label}</span><span class="value">${m.value}</span><span class="sub">${m.sub}</span>`;
    bar.appendChild(div);
  });
}

function buildTag(type) {
  const span = document.createElement('span');
  span.className = type === 'iron' ? 'iron-tag' : 'c-tag';
  span.textContent = type === 'iron' ? '🩸' : '🍋';
  return span;
}

function renderPersonCard(data, person) {
  const div = document.createElement('div');
  div.className = `person-card ${person} ${person}-only`;
  const nameTag = document.createElement('div');
  nameTag.className = 'person-name-tag';
  nameTag.textContent = person === 'debra' ? '💗 Debra' : '💙 Bryan';
  const title = document.createElement('div');
  title.className = 'meal-title';
  title.textContent = data.title;
  const flavor = document.createElement('div');
  flavor.className = 'meal-flavor';
  flavor.textContent = data.flavor;
  const items = document.createElement('div');
  items.className = 'meal-items';
  data.items.forEach(item => {
    const line = document.createElement('div');
    line.textContent = item.text;
    if (item.iron) line.appendChild(buildTag('iron'));
    if (item.vitc) line.appendChild(buildTag('vitc'));
    items.appendChild(line);
  });
  div.appendChild(nameTag);
  div.appendChild(title);
  div.appendChild(flavor);
  div.appendChild(items);
  return div;
}

function renderDay(day, index) {
  const card = document.createElement('div');
  card.className = 'day-card';

  const header = document.createElement('div');
  header.className = `day-header ${day.type}`;

  const nameSpan = document.createElement('span');
  nameSpan.className = 'day-name';
  nameSpan.textContent = day.name;

  const meta = document.createElement('div');
  meta.className = 'day-meta';

  const badge = document.createElement('span');
  badge.className = `badge ${day.type}`;
  badge.textContent = day.type === 'training' ? '🏋️ Training' : '🌿 Rest';
  meta.appendChild(badge);

  if (day.ironPriority === 'high') {
    const ironBadge = document.createElement('span');
    ironBadge.className = 'badge iron';
    ironBadge.textContent = '🩸 High Iron';
    meta.appendChild(ironBadge);
  }

  if (day.homeWorkout) {
    const hwBadge = document.createElement('span');
    hwBadge.className = 'badge home';
    hwBadge.textContent = '💜 Home Option';
    meta.appendChild(hwBadge);
  }

  const chevron = document.createElement('span');
  chevron.className = 'chevron';
  chevron.textContent = '▼';
  meta.appendChild(chevron);

  header.appendChild(nameSpan);
  header.appendChild(meta);

  const body = document.createElement('div');
  body.className = 'day-body' + (index === 0 ? ' open' : '');

  // Workout inline block
  if (day.homeWorkout) {
    const workoutBlock = document.createElement('div');
    workoutBlock.className = 'workout-inline';
    workoutBlock.innerHTML = `
      <div class="workout-inline-label">💜 Home Alternative</div>
      <div class="workout-inline-title">${day.homeWorkout}</div>
      <div style="font-size:11px;color:var(--text-mid)">Tap the <strong>Home Workouts</strong> tab above for the full routine with sets + reps.</div>
    `;
    body.appendChild(workoutBlock);
  }

  day.slots.forEach(slot => {
    const slotDiv = document.createElement('div');
    slotDiv.className = 'meal-slot';
    const slotLabel = document.createElement('div');
    slotLabel.className = 'slot-label';
    slotLabel.textContent = slot.slot;
    slotDiv.appendChild(slotLabel);
    const personsRow = document.createElement('div');
    personsRow.className = 'persons-row';
    personsRow.appendChild(renderPersonCard(slot.debra, 'debra'));
    personsRow.appendChild(renderPersonCard(slot.bryan, 'bryan'));
    slotDiv.appendChild(personsRow);
    if (slot.shared) {
      const note = document.createElement('div');
      note.className = 'shared-note';
      note.textContent = '🍳 ' + slot.shared;
      slotDiv.appendChild(note);
    }
    body.appendChild(slotDiv);
  });

  const tip = document.createElement('div');
  tip.className = 'day-tip';
  tip.innerHTML = day.tip;
  body.appendChild(tip);

  card.appendChild(header);
  card.appendChild(body);

  header.addEventListener('click', () => {
    const isOpen = body.classList.contains('open');
    document.querySelectorAll('.day-body').forEach(b => b.classList.remove('open'));
    document.querySelectorAll('.chevron').forEach(c => c.style.transform = '');
    if (!isOpen) {
      body.classList.add('open');
      chevron.style.transform = 'rotate(180deg)';
    }
  });

  if (index === 0) chevron.style.transform = 'rotate(180deg)';
  return card;
}

